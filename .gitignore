# Since the choice of what to enable is machine-specific, we'll ignore everything that eventually
# gets created in enabled except for the default bootstrap and a starer script to make symlinks
enabled/*
!enabled/00-bootstrap
!enabled/mklinks.sh

# Per-machine Claude Code settings — both files are personal preference, not shared config
.claude/settings.json
.claude/settings.local.json

# Local scratch space for repo-level dev tools (test scripts, etc.) — not committed
.bin/

