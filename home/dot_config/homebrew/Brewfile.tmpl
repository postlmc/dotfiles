# Bootstrap tool — must stay in Homebrew so it can manage everything else
brew "chezmoi"

{{- if eq .chezmoi.os "darwin" }}

# Newer bash (macOS ships 3.2.x)
brew "bash"

# System networking
brew "iproute2mac"

# Virtualization
brew "qemu"
brew "vde"

# Database servers (brew services)
brew "postgresql@14"
brew "mysql"

# Security scanning (brew services)
brew "clamav"

# Developer tools that must stay in Homebrew
brew "dotnet"

# macOS-specific utilities
brew "age-plugin-se"

# Fonts
cask "font-fira-code-nerd-font"
cask "font-monaspace"
cask "font-sf-mono-nerd-font-ligaturized"

# Security
cask "1password-cli"
cask "git-credential-manager"
cask "keepassxc"
cask "knockknock"
cask "osquery"
cask "taskexplorer"

# GUI applications
cask "bruno"
cask "claude-code"
cask "cmux"
cask "packetsender"
cask "qlmarkdown"
cask "raycast"
cask "visual-studio-code"
cask "wireshark-app"

# AWS
cask "copilot-cli"

{{- end }}

{{- if dig "development" "docker" false . }}
# Container tools
brew "podman"
brew "podman-compose"
{{- if eq .chezmoi.os "darwin" }}
cask "podman-desktop"
{{- end }}
{{- end }}

{{- if dig "cloud" "azure" false . }}
# Azure tools (Homebrew per Microsoft's recommendations)
tap "azure/functions"
tap "azure/kubelogin"
brew "azure-cli"
brew "azcopy"
brew "aztfexport"
brew "azure/functions/azure-functions-core-tools@4"
brew "azure/kubelogin/kubelogin"
{{- end }}

{{- if dig "cloud" "gcloud" false . }}
# Google Cloud tools
cask "google-cloud-sdk"
{{- end }}

{{- if dig "development" "kubernetes" false . }}
# Kubernetes tools not available in nixpkgs on macOS
brew "calicoctl"
{{- end }}

{{- if dig "tools" "sdr" false . }}
# SDR / hardware driver stack
{{- if eq .chezmoi.os "darwin" }}
brew "airspy"
brew "airspyhf"
brew "esptool"
brew "f3"
brew "hackrf"
brew "soapyrtlsdr"
brew "soapysdr"
{{- end }}
{{- end }}
