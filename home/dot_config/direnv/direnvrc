# from: https://github.com/direnv/direnv/wiki/Python#uv
layout_uv() {
    if [[ -d ".venv" ]]; then
        VIRTUAL_ENV="$(pwd)/.venv"
    fi

    if [[ -z $VIRTUAL_ENV || ! -d $VIRTUAL_ENV ]]; then
        log_status "No virtual environment exists. Executing \`uv venv\` to create one."
        if [[ -f ".python-version" ]]; then
            uv venv --python "$(cat .python-version)"
        else
            uv venv
        fi
        VIRTUAL_ENV="$(pwd)/.venv"
    fi

    PATH_add "$VIRTUAL_ENV/bin"
    export UV_ACTIVE=1
    export VIRTUAL_ENV
}

# Activate a project devbox environment and re-add Homebrew to PATH.
# devbox shellenv prepends nix store paths without preserving the Homebrew prefix,
# so PATH_add restores it after devbox runs. Use in .envrc as: layout devbox
layout_devbox() {
    eval "$(devbox shellenv --init-hook --install --no-refresh-alias)"
    watch_file devbox.json devbox.lock
    [[ -n "${HOMEBREW_PREFIX}" && -d "${HOMEBREW_PREFIX}/bin" && ":${PATH}:" != *":${HOMEBREW_PREFIX}/bin:"* ]] && \
        PATH_add "${HOMEBREW_PREFIX}/bin"
}

# Load a lifecycle-specific .env file selected by .env.choice, falling back to .env.
# Create .env.production, .env.development, etc. and write the desired name into
# .env.choice to switch between them. direnv reloads automatically when .env.choice
# changes. Use in .envrc as: layout dotenv
layout_dotenv() {
    local env_file=".env"
    if [[ -f ".env.choice" ]]; then
        local choice
        choice=$(< .env.choice)
        [[ -f ".env.${choice}" ]] && env_file=".env.${choice}"
    fi
    watch_file .env.choice
    [[ -f "$env_file" ]] && dotenv "$env_file"
}
