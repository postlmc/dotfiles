#!/bin/bash
# Configure VS Code to use bash with ACTIVE_AGENT for Copilot terminal
# hash: {{ include "dot_local/bin/executable_copilot-podman-terminal.sh" | sha256sum }}

# Detect OS and set appropriate paths
if [[ "$OSTYPE" == "darwin"* ]]; then
    SETTINGS_FILE="$HOME/Library/Application Support/Code/User/settings.json"
    PROFILE_KEY="chat.tools.terminal.terminalProfile.osx"
else
    SETTINGS_FILE="$HOME/.config/Code/User/settings.json"
    PROFILE_KEY="chat.tools.terminal.terminalProfile.linux"
fi

mkdir -p "$(dirname "$SETTINGS_FILE")"
[[ -f "$SETTINGS_FILE" ]] || echo '{}' > "$SETTINGS_FILE"

# Live settings.json is JSONC in practice (VS Code writes comments), which jq can't parse.
# If the key is already present, leave the file alone; delete the key to force a rewrite.
if grep -q "\"$PROFILE_KEY\"" "$SETTINGS_FILE"; then
    exit 0
fi

# jq can't parse JSONC — bail rather than corrupt a settings file that has comments or trailing commas
if ! jq empty "$SETTINGS_FILE" 2>/dev/null; then
    echo "Warning: $SETTINGS_FILE is not strict JSON and $PROFILE_KEY is missing; add it manually" >&2
    exit 0
fi

# To run Copilot terminals in a container instead, set "path" to "$HOME/.local/bin/copilot-podman-terminal.sh"
tmp=$(mktemp) || exit 1
jq --arg key "$PROFILE_KEY" '.[$key] = {
    "path": "bash",
    "env": {
        "ACTIVE_AGENT": "Copilot"
    }
}' "$SETTINGS_FILE" > "$tmp" && mv "$tmp" "$SETTINGS_FILE" || { rm -f "$tmp"; exit 1; }

echo "Updated VS Code settings: $PROFILE_KEY -> bash with ACTIVE_AGENT=Copilot"
