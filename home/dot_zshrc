#!/bin/zsh

# macOS path_helper
[[ "$OSTYPE" == darwin* ]] && whence -w /usr/libexec/path_helper >/dev/null 2>&1 && \
    eval $(/usr/libexec/path_helper -s)

# devbox (universal)
whence -w /usr/local/bin/devbox >/dev/null 2>&1 && \
    eval "$(/usr/local/bin/devbox global shellenv --init-hook)"

# Homebrew setup
if [[ "$OSTYPE" == darwin* ]]; then
    # macOS Homebrew
    whence -w /opt/homebrew/bin/brew >/dev/null 2>&1 && \
        eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ "$OSTYPE" == linux* ]]; then
    # Linux Homebrew
    whence -w /var/home/linuxbrew/.linuxbrew/bin/brew >/dev/null 2>&1 && \
        eval "$(/var/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# direnv
command -v direnv &>/dev/null && eval "$(direnv hook zsh)"

# Source all enabled modules (aliases, env vars, functions only)
CHEZMOI_SOURCE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/chezmoi"
for CFG in ${CHEZMOI_SOURCE_DIR}/enabled/??-*; do
    [[ -f "$CFG" ]] && . ${CFG}
done

# Home PATH additions
[[ -d "${HOME}/.local/bin" ]] && prepend_path PATH ${HOME}/.local/bin
[[ -d "${HOME}/bin" ]] && prepend_path PATH ${HOME}/bin


if [[ -z "${ACTIVE_AGENT}" ]]; then
    # This is a regular interactive shell, so load full configuration
    
    # Color and display aliases
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
    
    # Common ls variations for different detail levels
    alias ll='ls -l'
    alias la='ls -la'
    alias l='ls -CF'
    
    # Common typos
    alias ls-la='ls -la'
    alias ls-l='ls -l'
    
    # Show octal permissions for easier chmod reference
    alias lso="ls -alG | \
        awk '{k=0;for(i=0;i<=8;i++)k+=((substr(\$1,i+2,1)~/[rwx]/)*2^(8-i));if(k)printf(\" %0o \",k);print}'"
    
    # Completion System

    # FPATH additions (must be before compinit)
    fpath=(~/.zsh/completion $fpath)

    # Completion styles
    ZSH_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
    [[ ! -d "$ZSH_CACHE_DIR" ]] && mkdir -p "$ZSH_CACHE_DIR"
    zstyle ':completion:*' use-cache on
    zstyle ':completion:*' cache-path "$ZSH_CACHE_DIR"

    # Initialize completion (once)
    autoload -U +X compinit && compinit
    autoload -U +X bashcompinit && bashcompinit

    # Tool-specific completions

    # Azure CLI completion (installed via Homebrew)
    [[ -f "${HOMEBREW_PREFIX}/etc/bash_completion.d/az" ]] && source "${HOMEBREW_PREFIX}/etc/bash_completion.d/az"

    # Kubernetes (completions cached — rm ~/.cache/zsh/kubectl.zsh etc. to regenerate)
    if (( $+commands[kubectl] )); then
        _kc="${ZSH_CACHE_DIR}/kubectl.zsh"
        [[ ! -f "$_kc" ]] && kubectl completion zsh 2>/dev/null > "$_kc"
        [[ -f "$_kc" ]] && source "$_kc"
        unset _kc
    fi
    if (( $+commands[kubelogin] )); then
        _kc="${ZSH_CACHE_DIR}/kubelogin.zsh"
        [[ ! -f "$_kc" ]] && kubelogin completion zsh 2>/dev/null > "$_kc"
        [[ -f "$_kc" ]] && source "$_kc"
        unset _kc
    fi

    # Plugins
    [[ -f ${HOME}/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
        source ${HOME}/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
    [[ -f ${HOME}/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
        source ${HOME}/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
    [[ -f ${HOME}/.zsh/zsh-hist/zsh-hist.plugin.zsh ]] && \
        source ${HOME}/.zsh/zsh-hist/zsh-hist.plugin.zsh

    # 1Password (completion cached — rm ~/.cache/zsh/op.zsh to regenerate)
    if (( $+commands[op] )); then
        _opc="${ZSH_CACHE_DIR}/op.zsh"
        [[ ! -f "$_opc" ]] && op completion zsh 2>/dev/null > "$_opc"
        [[ -f "$_opc" ]] && source "$_opc"
        unset _opc
    fi

    # Everything else preferred in interactive shells

    [[ -f ${HOME}/.fzf.zsh ]] && source ${HOME}/.fzf.zsh
    (( $+commands[fzf] )) && eval "$(fzf --zsh)"

    export HISTFILE=~/.zsh_history
    export HISTSIZE=1200000
    export SAVEHIST=1000000
    unsetopt SHARE_HISTORY
    setopt HIST_IGNORE_SPACE HIST_IGNORE_ALL_DUPS HIST_SAVE_NO_DUPS
    setopt HIST_FIND_NO_DUPS HIST_EXPIRE_DUPS_FIRST HIST_REDUCE_BLANKS
    unsetopt INC_APPEND_HISTORY
    setopt INC_APPEND_HISTORY_TIME EXTENDED_HISTORY

    unalias run-help 2>/dev/null
    autoload run-help

    # Host-specific local config
    _local_shell="${HOME}/.config/dotfiles.local/shell/${$(hostname -s):l}"
    [[ -f "$_local_shell" ]] && . "$_local_shell"
    unset _local_shell

    set -o vi

    if command -v starship &>/dev/null; then
        export STARSHIP_CONFIG=${HOME}/.config/starship/starship.toml
        eval "$(starship init zsh)"
    fi

else
    # This is an agent shell so load a minimal configuration
    export HISTFILE=/dev/null
    export HISTSIZE=0
    export SAVEHIST=0
    unsetopt SHARE_HISTORY

    export NO_COLOR=1
    export TERM=dumb
    export PAGER=cat
    export GIT_PAGER=ca

    export CLICOLOR=0
    export LC_ALL=C
    export LANG=C
fi
