#!/bin/bash

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# devbox (universal)
command -v /usr/local/bin/devbox >/dev/null 2>&1 && \
    eval "$(/usr/local/bin/devbox global shellenv --init-hook)"

# Homebrew setup
if [[ "$OSTYPE" == darwin* ]]; then
    # macOS Homebrew
    command -v /opt/homebrew/bin/brew >/dev/null 2>&1 && \
        eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ "$OSTYPE" == linux* ]]; then
    # Linux Homebrew
    command -v /var/home/linuxbrew/.linuxbrew/bin/brew >/dev/null 2>&1 && \
        eval "$(/var/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# direnv
command -v direnv &>/dev/null && eval "$(direnv hook bash)"

# Source all enabled modules (aliases, env vars, functions only)
CHEZMOI_SOURCE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/chezmoi"
for CFG in ${CHEZMOI_SOURCE_DIR}/enabled/??-*; do
    [[ -f "$CFG" ]] && . ${CFG}
done

# Home PATH additions
[[ -d "${HOME}/.local/bin" ]] && prepend_path PATH ${HOME}/.local/bin
[[ -d "${HOME}/bin" ]] && prepend_path PATH ${HOME}/bin



if [[ -z "${ACTIVE_AGENT}" ]]; then
    # This is a regular interactive shell, so load full configuration

    # Completion System

    # Source bash completion
    [[ -f /etc/bash_completion ]] && . /etc/bash_completion

    # Tool-specific completions

    # Azure CLI completion (installed via Homebrew)
    [[ -f "${HOMEBREW_PREFIX}/etc/bash_completion.d/az" ]] && . "${HOMEBREW_PREFIX}/etc/bash_completion.d/az"

    # Kubernetes (completions cached — rm ~/.cache/bash/kubectl.bash etc. to regenerate)
    _BASH_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/bash"
    [[ ! -d "$_BASH_CACHE" ]] && mkdir -p "$_BASH_CACHE"
    if command -v kubectl &>/dev/null; then
        _kc="${_BASH_CACHE}/kubectl.bash"
        [[ ! -f "$_kc" ]] && kubectl completion bash 2>/dev/null > "$_kc"
        [[ -f "$_kc" ]] && source "$_kc"
        unset _kc
    fi
    if command -v kubelogin &>/dev/null; then
        _kc="${_BASH_CACHE}/kubelogin.bash"
        [[ ! -f "$_kc" ]] && kubelogin completion bash 2>/dev/null > "$_kc"
        [[ -f "$_kc" ]] && source "$_kc"
        unset _kc
    fi
    unset _BASH_CACHE

    # Everything else preferred in interactive shells

    [[ -f ${HOME}/.fzf.bash ]] && source ${HOME}/.fzf.bash
    command -v fzf &>/dev/null && eval "$(fzf --bash)"

    export HISTFILE=~/.bash_history
    export HISTSIZE=1200000
    export HISTFILESIZE=1200000
    export HISTCONTROL=ignoreboth:erasedups
    export HISTIGNORE="&:ls:[bf]g:exit"
    shopt -s histappend

    shopt -s checkwinsize

    # Function to toggle shell options via aliases
    shopt-alias() {
        for OPT in $(shopt | awk '{print $1}'); do
            if ! command -v $OPT >/dev/null 2>&1 && ! alias $OPT 2>/dev/null && ! declare -f $OPT >/dev/null 2>&1; then
                alias $OPT="if shopt -q $OPT; then shopt -u $OPT && echo \"$OPT off\"; \
                    else shopt -s $OPT && echo \"$OPT on\"; fi"
            fi
        done
    }
    shopt-alias

    # Host-specific local config
    _local_shell="${HOME}/.config/dotfiles.local/shell/$(hostname -s | tr '[:upper:]' '[:lower:]')"
    [[ -f "$_local_shell" ]] && . "$_local_shell"
    unset _local_shell

    set -o vi

    if command -v starship &>/dev/null; then
        export STARSHIP_CONFIG=${HOME}/.config/starship/starship.toml
        eval "$(starship init bash)"
    fi

else
    # This is an agent shell so load a minimal configuration
    export HISTFILE=/dev/null
    export HISTSIZE=0
    export HISTFILESIZE=0
    unset HISTCONTROL HISTIGNORE

    export NO_COLOR=1
    export TERM=dumb
    export PAGER=cat
    export GIT_PAGER=cat

    export CLICOLOR=0
    export LC_ALL=C
    export LANG=C
fi
