#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = []
# ///
"""Reformat GFM tables in a Markdown file to markdownlint MD060 "aligned" style.

Pads every cell to the max display width in its column so all pipes align, and
skips fenced code blocks so shell and mermaid pipes are left untouched. Rewrites
the given file in place.

Usage:
    align-tables <file.md>
"""
import re
import sys
import unicodedata

SEP_RE = re.compile(r'^\s*\|?[\s:|-]*-[\s:|-]*\|?\s*$')
FENCE_RE = re.compile(r'^\s*(```|~~~)')

Align = tuple[bool, bool]


def dwidth(s: str) -> int:
    """Return display width matching MD060: wide/fullwidth = 2, combining = 0."""
    w = 0
    for ch in s:
        if unicodedata.combining(ch):
            continue
        w += 2 if unicodedata.east_asian_width(ch) in ('W', 'F') else 1
    return w


def is_sep(line: str) -> bool:
    """Return True if the line is a table separator row (e.g. | --- | :-: |)."""
    return '|' in line and '-' in line and SEP_RE.match(line) is not None


def split_row(line: str) -> list[str]:
    """Split a table row into stripped cell strings, dropping the edge pipes."""
    s = line.strip()
    if s.startswith('|'):
        s = s[1:]
    if s.endswith('|'):
        s = s[:-1]
    return [c.strip() for c in s.split('|')]


def parse_align(sep_cells: list[str]) -> list[Align]:
    """Map each separator cell to its (left, right) alignment colons."""
    return [(c.startswith(':'), c.endswith(':')) for c in sep_cells]


def fmt_table(header: str, sep: str, rows: list[str]) -> list[str]:
    """Reformat one table into aligned lines: header, separator, then body."""
    hcells = split_row(header)
    aligns = parse_align(split_row(sep))
    body = [split_row(r) for r in rows]
    ncol = len(hcells)
    widths = [dwidth(h) for h in hcells]
    for row in body:
        for i in range(min(ncol, len(row))):
            widths[i] = max(widths[i], dwidth(row[i]))

    def pad(cell: str, i: int) -> str:
        """Pad a cell to its column width, honoring alignment colons."""
        left, right = aligns[i] if i < len(aligns) else (False, False)
        fill = widths[i] - dwidth(cell)
        if left and right:
            half = fill // 2
            return ' ' * half + cell + ' ' * (fill - half)
        if right:
            return ' ' * fill + cell
        return cell + ' ' * fill

    def build(cells: list[str]) -> str:
        """Build a padded content row, filling any missing trailing cells."""
        out = [pad(cells[i] if i < len(cells) else '', i) for i in range(ncol)]
        return '| ' + ' | '.join(out) + ' |'

    def build_sep() -> str:
        """Build the compact separator row: dashes span the full cell width."""
        segs = []
        for i in range(ncol):
            left, right = aligns[i] if i < len(aligns) else (False, False)
            total = widths[i] + 2
            if left and right:
                seg = ':' + '-' * (total - 2) + ':'
            elif right:
                seg = '-' * (total - 1) + ':'
            elif left:
                seg = ':' + '-' * (total - 1)
            else:
                seg = '-' * total
            segs.append(seg)
        return '|' + '|'.join(segs) + '|'

    return [build(hcells), build_sep()] + [build(r) for r in body]


def align_tables(text: str) -> str:
    """Return the Markdown text with every table outside a code fence aligned."""
    lines = text.split('\n')
    out: list[str] = []
    in_fence = False
    i = 0
    n = len(lines)
    while i < n:
        line = lines[i]
        if FENCE_RE.match(line):
            in_fence = not in_fence
            out.append(line)
            i += 1
            continue
        starts_table = (
            not in_fence and '|' in line and not is_sep(line)
            and i + 1 < n and is_sep(lines[i + 1])
        )
        if starts_table:
            rows = []
            j = i + 2
            while j < n and '|' in lines[j] and lines[j].strip() and not is_sep(lines[j]):
                rows.append(lines[j])
                j += 1
            out.extend(fmt_table(line, lines[i + 1], rows))
            i = j
            continue
        out.append(line)
        i += 1
    return '\n'.join(out)


def main(argv: list[str]) -> int:
    """Align tables in the file named by argv[1], rewriting it in place."""
    if len(argv) == 2 and argv[1] in ('-h', '--help'):
        print('Usage: align-tables <file.md>')
        return 0
    if len(argv) != 2:
        print('Usage: align-tables <file.md>', file=sys.stderr)
        return 2
    path = argv[1]
    with open(path, encoding='utf-8') as f:
        text = f.read()
    with open(path, 'w', encoding='utf-8') as f:
        f.write(align_tables(text))
    return 0


if __name__ == '__main__':
    sys.exit(main(sys.argv))
