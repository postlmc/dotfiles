    "zellij@latest"
    "nushell@latest"
    "starship@latest"
    "direnv@latest"
    "fzf@latest"
    "bat@latest"
    "tree@latest"
    "watch@latest"
    "television@latest"
    "pv@latest"
    "parallel@latest"
    "stow@latest"
    "vim@latest"
    "ripgrep@latest"
    "jq@latest"
