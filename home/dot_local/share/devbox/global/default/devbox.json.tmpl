    "imagemagick@latest"
    "gnuplot@latest"
    "tesseract@latest"
    "exiftool@latest"
    "just@latest"
    "websocat@latest"
    "oath-toolkit@latest"
    "tmux-xpanes@latest"
    "mediainfo@latest"
    "qpdf@latest"
    "age-plugin-yubikey@latest"
    "cfssl@latest"
-}}
{{- /* Python tooling — uv manages runtimes, no python runtime here */ -}}
{{- if dig "development" "python" false . -}}
{{- $pkgs = append $pkgs "uv@latest" -}}
{{- end -}}
{{- /* Go and Rust are project-specific — not installed globally */ -}}
{{- /* Kubernetes tools */ -}}
{{- if dig "development" "kubernetes" false . -}}
{{- $pkgs = append $pkgs "kubectl@1.30" -}}
{{- $pkgs = append $pkgs "kubectx@latest" -}}
{{- $pkgs = append $pkgs "kubernetes-helm@latest" -}}
{{- $pkgs = append $pkgs "k9s@latest" -}}
{{- $pkgs = append $pkgs "argocd@latest" -}}
{{- $pkgs = append $pkgs "kubeconform@latest" -}}
{{- $pkgs = append $pkgs "kubetail@latest" -}}
{{- $pkgs = append $pkgs "kustomize@latest" -}}
{{- $pkgs = append $pkgs "talosctl@latest" -}}
{{- $pkgs = append $pkgs "cmctl@latest" -}}
{{- $pkgs = append $pkgs "kompose@latest" -}}
{{- $pkgs = append $pkgs "argo@latest" -}}
{{- $pkgs = append $pkgs "calicoctl@latest" -}}
{{- end -}}
{{- /* Azure tools managed by Homebrew per Microsoft's recommendations */ -}}
{{- /* Terraform */ -}}
{{- if dig "tools" "terraform" false . -}}
{{- $pkgs = append $pkgs "terraform@latest" -}}
{{- $pkgs = append $pkgs "cf-terraforming@latest" -}}
{{- end -}}
{{- /* Monitoring / TUI tools */ -}}
{{- if dig "tools" "monitoring" false . -}}
{{- $pkgs = append $pkgs "gum@latest" -}}
{{- end -}}
{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
    "packages": {{ $pkgs | toJson }},
    "shell": {
        "init_hook": [],
        "scripts": {
            "test": [
                "echo \"Error: no test specified\" && exit 1"
            ]
        }
    }
}
